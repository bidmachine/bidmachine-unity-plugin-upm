{
  "git": {
    "commit": true,
    "commitMessage": "chore: prepare v${version} release",
    "tag": true,
    "tagName": "v${version}",
    "push": true,
    "requireCleanWorkingDir": true,
    "requireBranch": "release/*"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "draft": true
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits"
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog",
      "ignoreRecommendedBump": true,
      "context": {
        "host": "https://github.com",
        "owner": "bidmachine",
        "repository": "bidmachine-unity-plugin-upm",
        "repoUrl": "https://github.com/bidmachine/bidmachine-unity-plugin-upm"
      }
    }
  }
}
